{
  "name": "@scrambleiq/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prestart": "npm run build --workspace @scrambleiq/shared",
    "prestart:dev": "npm run build --workspace @scrambleiq/shared"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "@scrambleiq/shared": "file:../../packages/shared"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/testing": "^11.0.1",
    "@types/node": "^22.13.11",
    "supertest": "^7.1.0",
    "vitest": "^3.0.9"
  }
}
